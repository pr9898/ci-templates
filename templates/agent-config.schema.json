{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pr9898/ci-templates/agent-config.schema.json",
  "title": "Agent Configuration",
  "description": "Agent 配置文件 Schema。用于 ajv 校验，确保配置字段完整、类型正确。",
  "type": "object",
  "required": ["name", "version", "model", "tools"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "description": "Agent 名称"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "语义化版本号"
    },
    "description": {
      "type": "string",
      "maxLength": 512
    },
    "model": {
      "type": "object",
      "required": ["provider", "name"],
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["openai", "anthropic", "azure", "custom"]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "temperature": {
          "type": "number",
          "minimum": 0,
          "maximum": 2
        },
        "maxTokens": {
          "type": "integer",
          "minimum": 1,
          "maximum": 128000
        }
      }
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": ["function", "http", "mcp"]
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "systemPrompt": {
      "type": "string",
      "maxLength": 8192
    },
    "safetyFilters": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["prompt-injection", "pii", "toxicity", "hallucination"]
      }
    }
  }
}
